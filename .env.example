# ── Copy this file to .env and fill in your values ──────────────────────────
# .env is listed in .gitignore and will NEVER be pushed to GitHub

# WhatsApp Business API
WHATSAPP_TOKEN=your_permanent_access_token_here
PHONE_NUMBER_ID=your_phone_number_id_here
VERIFY_TOKEN=choose_any_secret_string_here

# Google Sheets
SHEET_ID=your_google_sheet_id_here
# Paste the entire contents of credentials.json as a single-line JSON string
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Authorized phone numbers in E.164 format WITHOUT the + sign
# Manager can ADD and TAKE stock
MANAGER_NUMBERS=972501234567
# Employees can only TAKE stock — separate multiple numbers with commas
EMPLOYEE_NUMBERS=972501234568,972501234569
