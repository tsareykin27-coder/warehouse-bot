# ── Copy this file to .env and fill in your values ───────────────────────────
# .env is listed in .gitignore and will NEVER be pushed to GitHub

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=1234567890:ABCDefghIJKLmnopQRSTuvwxYZ

# Google Sheets
SHEET_ID=your_google_sheet_id_here
# Paste the entire contents of credentials.json as a single-line JSON string
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Authorized Telegram user IDs (numeric)
# How to find: message the bot from any account — if unauthorized,
# the bot replies with that user's Telegram ID. Paste it here.
MANAGER_IDS=123456789
# Multiple employees: comma-separated
EMPLOYEE_IDS=987654321,111222333
